<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/routineContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/activity_margin_actual"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/background_card"
    app:cardCornerRadius="@dimen/card_radius_default"
    app:cardElevation="@dimen/card_elevation_default"
    app:contentPadding="@dimen/margin_20">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:background="@color/background_card">

        <TextView
            android:id="@+id/routineName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toLeftOf="@id/rightArrow"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/white_base"
            android:textSize="20sp"
            tools:text="Routine Name" />

        <TextView
            android:id="@+id/routineSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/routineName"
            android:layout_marginTop="@dimen/activity_margin_half_half"
            android:layout_toLeftOf="@id/rightArrow"
            android:textColor="@color/gray_5"
            android:textSize="14sp"
            tools:text="9 exercises • 12 sets" />

        <ImageView
            android:id="@+id/rightArrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="@dimen/activity_margin_half"
            android:src="@drawable/ic_right"
            android:visibility="gone"
            app:tint="@color/gray_5"
            tools:visibility="visible" />
    </RelativeLayout>
</androidx.cardview.widget.CardView>