<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/weekShimmerView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:visibility="gone"
    app:shimmer_clip_to_children="true"
    tools:shimmer_base_alpha="1"
    tools:visibility="visible">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:background="@color/background_base">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="120dp"
                android:layout_height="20dp"
                android:background="@color/background_card" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_18"
                android:clipChildren="false"
                android:clipToPadding="false">

                <com.everlog.ui.views.summarycard.SummaryCardWeek
                    android:layout_width="0dp"
                    android:layout_height="@dimen/card_week_statistics_height"
                    android:layout_marginRight="@dimen/margin_26"
                    android:layout_weight="1" />

                <com.everlog.ui.views.summarycard.SummaryCardWeek
                    android:layout_width="0dp"
                    android:layout_height="@dimen/card_week_statistics_height"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.facebook.shimmer.ShimmerFrameLayout>