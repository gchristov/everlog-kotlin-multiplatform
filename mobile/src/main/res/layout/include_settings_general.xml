<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    tools:background="@color/background_base">

    <TextView
        style="@style/SettingsCategory"
        android:layout_marginBottom="@dimen/settings_category_title_margin_vertical"
        android:text="@string/settings_general" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/background_card"
        app:cardCornerRadius="@dimen/card_radius_default"
        app:cardElevation="@dimen/card_elevation_default">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/separator_line"
            android:orientation="vertical"
            android:showDividers="middle">

            <LinearLayout
                android:id="@+id/firstWeekDayBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingLeft="@dimen/settings_card_content_margin_left"
                android:paddingTop="@dimen/settings_row_padding_top"
                android:paddingRight="@dimen/settings_card_content_margin_left"
                android:paddingBottom="@dimen/settings_row_padding_bottom">

                <TextView
                    style="@style/SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_first_week_day" />

                <TextView
                    android:id="@+id/firstWeekDayField"
                    style="@style/SettingsValue"
                    tools:text="Monday" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/weightUnitBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingLeft="@dimen/settings_card_content_margin_left"
                android:paddingTop="@dimen/settings_row_padding_top"
                android:paddingRight="@dimen/settings_card_content_margin_left"
                android:paddingBottom="@dimen/settings_row_padding_bottom">

                <TextView
                    style="@style/SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_unit_weight" />

                <TextView
                    android:id="@+id/weightUnitField"
                    style="@style/SettingsValue"
                    tools:text="@string/settings_kilograms" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>