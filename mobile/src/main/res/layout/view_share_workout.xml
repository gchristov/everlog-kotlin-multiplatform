<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_base"
    android:gravity="center"
    android:orientation="vertical"
    tools:layout_height="@dimen/share_workout_size"
    tools:layout_width="@dimen/share_workout_size">

    <TextView
        android:id="@+id/nameField"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="@dimen/activity_margin"
        android:layout_marginTop="@dimen/activity_margin_half_half"
        android:layout_marginRight="@dimen/activity_margin"
        android:layout_marginBottom="@dimen/activity_margin_half_half"
        android:layout_weight="1"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Build: CHEST / TRIS"
        android:textColor="@color/white_base"
        android:textSize="16sp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/activity_margin"
        android:layout_marginRight="@dimen/activity_margin"
        android:layout_marginBottom="@dimen/activity_margin_half_half"
        app:cardBackgroundColor="@color/background_card"
        app:cardCornerRadius="@dimen/card_radius_default"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/margin_10">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginRight="@dimen/activity_margin_half"
                android:src="@drawable/ic_flag_filled"
                app:tint="@color/main_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/sets"
                android:textAllCaps="true"
                android:textColor="@color/gray_2"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/setsField"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white_base"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="24" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/activity_margin"
        android:layout_marginTop="@dimen/activity_margin_half_half"
        android:layout_marginRight="@dimen/activity_margin"
        android:layout_marginBottom="@dimen/activity_margin_half_half"
        app:cardBackgroundColor="@color/background_card"
        app:cardCornerRadius="@dimen/card_radius_default"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/margin_10">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginRight="11dp"
                android:src="@drawable/ic_weight"
                app:tint="@color/main_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_week_weight_lifted_no_spaces"
                android:textAllCaps="true"
                android:textColor="@color/gray_2"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/weightField"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white_base"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="5432 kg" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/activity_margin"
        android:layout_marginTop="@dimen/activity_margin_half_half"
        android:layout_marginRight="@dimen/activity_margin"
        android:layout_marginBottom="@dimen/activity_margin_half_half"
        app:cardBackgroundColor="@color/background_card"
        app:cardCornerRadius="@dimen/card_radius_default"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/margin_10">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginRight="@dimen/activity_margin_half"
                android:src="@drawable/ic_time"
                app:tint="@color/main_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/workout_details_duration"
                android:textAllCaps="true"
                android:textColor="@color/gray_2"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/timeField"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white_base"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="0:59 h" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/activity_margin"
        android:layout_marginTop="@dimen/activity_margin_half_half"
        android:layout_marginRight="@dimen/activity_margin"
        android:layout_marginBottom="@dimen/activity_margin_half_half"
        app:cardBackgroundColor="@color/background_card"
        app:cardCornerRadius="@dimen/card_radius_default"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/margin_10">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginRight="@dimen/activity_margin_half"
                android:src="@drawable/ic_barbell"
                app:tint="@color/main_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/exercises_title"
                android:textAllCaps="true"
                android:textColor="@color/gray_2"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/exercisesField"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white_base"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="10" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_10"
        android:layout_weight="1"
        android:gravity="center">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="-6dp"
            android:padding="@dimen/margin_6"
            android:src="@drawable/ic_logo_text"
            app:tint="@color/white_base" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0.7dp"
            android:fontFamily="sans-serif-medium"
            android:text="for Android"
            android:textColor="@color/gray_3"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>