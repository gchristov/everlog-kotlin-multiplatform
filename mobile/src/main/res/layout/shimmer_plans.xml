<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/shimmerViewPlans"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:visibility="gone"
    app:shimmer_clip_to_children="true"
    tools:shimmer_base_alpha="1"
    tools:visibility="visible">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        tools:background="@color/background_base">

        <androidx.cardview.widget.CardView
            android:layout_width="@dimen/card_plan_width"
            android:layout_height="@dimen/card_plan_height"
            android:layout_marginRight="@dimen/margin_26"
            app:cardBackgroundColor="@color/background_card"
            app:cardCornerRadius="@dimen/card_radius_default"
            app:cardElevation="@dimen/card_elevation_default" />

        <androidx.cardview.widget.CardView
            android:layout_width="@dimen/card_plan_width"
            android:layout_height="@dimen/card_plan_height"
            app:cardBackgroundColor="@color/background_card"
            app:cardCornerRadius="@dimen/card_radius_default"
            app:cardElevation="@dimen/card_elevation_default" />
    </LinearLayout>
</com.facebook.shimmer.ShimmerFrameLayout>