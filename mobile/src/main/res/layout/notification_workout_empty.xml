<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notification_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_marginTop="-2dp"
        android:background="@color/background_card"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="@dimen/activity_margin"
        android:paddingRight="@dimen/activity_margin">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginRight="@dimen/margin_6"
                android:paddingTop="1dp"
                android:src="@drawable/ic_notification"
                app:tint="@color/white_darker" />

            <TextView
                android:id="@+id/titleLbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white_darker"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="@string/workout_empty_no_sets" />
        </LinearLayout>

        <TextView
            android:id="@+id/subtitleLbl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/activity_margin_half_half_half"
            android:text="@string/workout_empty_done_subtitle"
            android:textColor="@color/gray_2"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>