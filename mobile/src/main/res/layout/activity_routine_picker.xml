<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include layout="@layout/toolbar_transparent" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <com.everlog.ui.views.EmptyView
                android:id="@+id/emptyView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                app:evActionText="@string/routines_empty_action"
                app:evImage="@drawable/ic_routines"
                app:evSubtitle="@string/routines_empty_subtitle"
                app:evTitle="@string/routines_empty_title"
                tools:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:paddingLeft="@dimen/activity_margin_actual"
                android:paddingTop="@dimen/activity_margin_actual"
                android:paddingRight="@dimen/activity_margin_actual"
                android:paddingBottom="@dimen/footer_bottom_padding"
                tools:itemCount="3"
                tools:listitem="@layout/row_routine_picker" />

            <include layout="@layout/shimmer_routine_picker" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/addBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center|bottom"
                android:layout_margin="@dimen/activity_margin_actual"
                android:src="@drawable/ic_add_gray_2"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>