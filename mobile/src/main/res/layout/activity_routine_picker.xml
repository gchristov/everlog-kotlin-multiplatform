<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include
            android:id="@+id/appBar"
            layout="@layout/toolbar_transparent" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <com.everlog.ui.views.EmptyView
                android:id="@+id/emptyView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                app:evActionText="@string/routines_empty_action"
                app:evImage="@drawable/ic_routines"
                app:evSubtitle="@string/routines_empty_subtitle"
                app:evTitle="@string/routines_empty_title"
                tools:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:paddingLeft="@dimen/activity_margin"
                android:paddingTop="@dimen/activity_margin"
                android:paddingRight="@dimen/activity_margin"
                android:paddingBottom="@dimen/footer_bottom_padding"
                tools:itemCount="3"
                tools:listitem="@layout/row_routine_picker" />

            <include layout="@layout/shimmer_routine_picker" />

            <Button
                android:id="@+id/addBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|bottom"
                android:layout_margin="@dimen/activity_margin"
                android:background="@drawable/rounded_corners_new_workout_btn"
                android:clipToOutline="true"
                android:drawablePadding="@dimen/activity_margin_half"
                android:drawableStart="@drawable/ic_add_gray_2"
                android:drawableTint="@color/background_card"
                android:foreground="?attr/selectableItemBackground"
                android:paddingLeft="@dimen/activity_margin"
                android:paddingTop="@dimen/activity_margin_half"
                android:paddingRight="@dimen/activity_margin"
                android:paddingBottom="@dimen/activity_margin_half"
                android:text="@string/home_workouts_new_template"
                android:textAllCaps="false"
                android:textColor="@color/background_card"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>