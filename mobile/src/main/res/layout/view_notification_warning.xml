<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/containerLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/background_card_lighter"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="horizontal"
    android:padding="@dimen/activity_margin">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="@dimen/options_menu_icon_size"
        android:layout_height="@dimen/options_menu_icon_size"
        android:layout_marginRight="@dimen/activity_margin"
        app:tint="@color/gray_1"
        tools:padding="@dimen/activity_margin_half_half"
        tools:src="@drawable/ic_lock" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/titleLbl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/gray_2"
            android:textSize="16sp"
            tools:text="Free plans are limited to 1 day per week" />

        <TextView
            android:id="@+id/descriptionLbl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:textColor="@color/gray_1"
            android:textSize="14sp"
            tools:text="Upgrade to unlock them and to access unlimited plan schedule" />
    </LinearLayout>

    <ImageView
        android:id="@+id/closeBtn"
        android:layout_width="@dimen/options_menu_icon_size"
        android:layout_height="@dimen/options_menu_icon_size"
        android:layout_marginLeft="@dimen/activity_margin"
        android:layout_marginTop="-3dp"
        android:layout_marginRight="-8dp"
        android:padding="@dimen/activity_margin_half_half"
        android:src="@drawable/ic_clear_white"
        app:tint="@color/gray_1" />
</LinearLayout>