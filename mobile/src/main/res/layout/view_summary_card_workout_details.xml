<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:gravity="center"
    android:orientation="vertical"
    tools:background="@color/background_base">

    <TextView
        android:id="@+id/subtitleLbl"
        style="@style/SettingsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/workout_details_duration"
        android:textSize="13sp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/titleLbl"
            style="@style/SettingsValue"
            android:layout_width="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginRight="0dp"
            android:gravity="center"
            android:text="--"
            android:textColor="@color/white_base"
            android:textSize="22sp"
            tools:text="0:54" />

        <TextView
            android:id="@+id/metricLbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@+id/titleLbl"
            android:layout_marginLeft="@dimen/activity_margin_half_half_half"
            android:layout_marginBottom="@dimen/activity_margin_half_half_half"
            android:layout_toRightOf="@id/titleLbl"
            android:textColor="@color/gray_1"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="@string/kg"
            tools:visibility="visible" />
    </RelativeLayout>
</LinearLayout>