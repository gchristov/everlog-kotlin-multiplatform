<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingTop="@dimen/activity_margin"
    android:paddingBottom="@dimen/activity_margin"
    tools:background="@color/background_base">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.makeramen.roundedimageview.RoundedImageView
            android:id="@+id/userAvatar"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_centerInParent="true"
            android:background="@color/background_card"
            android:padding="@dimen/activity_margin"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_user"
            app:riv_corner_radius="45dp"
            app:riv_mutate_background="true" />

        <com.everlog.ui.views.badge.ProBadge
            android:id="@+id/proBadge"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignTop="@+id/userAvatar"
            android:layout_marginLeft="-26dp"
            android:layout_marginTop="-10dp"
            android:layout_toRightOf="@+id/userAvatar"
            android:visibility="gone"
            app:pbTextSize="12sp"
            tools:visibility="visible" />
    </RelativeLayout>

    <TextView
        android:id="@+id/userNameLbl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/activity_margin_half"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/white_base"
        android:textSize="20sp"
        tools:text="Georgi" />

    <Button
        android:id="@+id/manageProBtn"
        style="@style/Button"
        android:layout_width="wrap_content"
        android:layout_marginTop="@dimen/activity_margin_actual"
        android:visibility="gone"
        tools:text="upgrade to pro"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/proFreeTrialSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_12"
        android:textColor="@color/main_accent"
        android:textSize="13sp"
        android:visibility="gone"
        tools:text="@string/settings_pro_free_trial_today"
        tools:visibility="visible" />
</LinearLayout>