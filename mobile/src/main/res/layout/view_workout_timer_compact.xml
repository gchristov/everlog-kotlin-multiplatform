<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="?android:attr/actionBarSize"
    android:background="@color/main_accent"
    android:clickable="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical">

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/progress_bar_horizontal_inverted"
        android:indeterminate="false"
        android:max="100"
        android:progressDrawable="@drawable/progress_bar_horizontal_inverted"
        tools:progress="50" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/cancelBtn"
            android:layout_width="?android:attr/actionBarSize"
            android:layout_height="match_parent"
            android:padding="@dimen/activity_margin"
            android:src="@drawable/ic_clear_white"
            android:tint="@color/background_card" />

        <TextView
            android:id="@+id/titleLbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/activity_margin"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:textColor="@color/background_card"
            android:textSize="20sp"
            tools:text="Rest" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  •  "
            android:textColor="@color/background_card"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/timeField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/background_card"
            android:textSize="20sp"
            tools:text="60:00" />

        <ImageView
            android:id="@+id/decreaseBtn"
            android:layout_width="?android:attr/actionBarSize"
            android:layout_height="match_parent"
            android:layout_marginRight="-6dp"
            android:padding="@dimen/margin_14"
            android:src="@drawable/ic_replay_10"
            android:tint="@color/background_card" />

        <ImageView
            android:id="@+id/increaseBtn"
            android:layout_width="?android:attr/actionBarSize"
            android:layout_height="match_parent"
            android:padding="@dimen/margin_14"
            android:src="@drawable/ic_forward_10"
            android:tint="@color/background_card" />
    </LinearLayout>
</RelativeLayout>