<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_base"
    android:clipChildren="false"
    android:orientation="vertical">

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:translationY="50dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_above="@id/tabBar"
        android:background="@drawable/separator_line" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/background_toolbar"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_activity_home" />

    <Button
        android:id="@+id/newWorkoutBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/tabBar"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="@dimen/activity_margin"
        android:layout_marginBottom="@dimen/activity_margin"
        android:background="@drawable/rounded_corners_new_workout_btn"
        android:clipToOutline="true"
        android:drawablePadding="@dimen/activity_margin_half"
        android:drawableStart="@drawable/ic_add"
        android:drawableTint="@color/background_card"
        android:foreground="?attr/selectableItemBackground"
        android:paddingLeft="@dimen/activity_margin"
        android:paddingTop="@dimen/activity_margin_half"
        android:paddingRight="@dimen/activity_margin"
        android:paddingBottom="@dimen/activity_margin_half"
        android:text="@string/home_start_workout"
        android:textAllCaps="false"
        android:textColor="@color/background_card"
        android:textSize="16sp" />
</RelativeLayout>