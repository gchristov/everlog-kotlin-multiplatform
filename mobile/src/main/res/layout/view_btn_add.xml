<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_corners_btn_three"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingLeft="@dimen/activity_margin"
    android:paddingTop="@dimen/activity_margin_half_half"
    android:paddingRight="@dimen/activity_margin"
    android:paddingBottom="@dimen/activity_margin_half_half">

    <TextView
        android:id="@+id/addBtnTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add"
        android:textColor="@color/main_accent" />
</LinearLayout>