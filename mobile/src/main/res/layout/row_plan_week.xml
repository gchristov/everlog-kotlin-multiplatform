<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/activity_margin_actual"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/background_card"
    app:cardCornerRadius="@dimen/card_radius_default"
    app:cardElevation="@dimen/card_elevation_default">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="@dimen/margin_20">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titleField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/white_base"
                android:textSize="24sp"
                tools:text="Week 1" />

            <TextView
                android:id="@+id/detailsLbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/activity_margin_half_half_half"
                android:textColor="@color/gray_5"
                android:textSize="16sp"
                tools:text="3 workouts" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/menuBtn"
            android:layout_width="@dimen/options_menu_icon_size"
            android:layout_height="@dimen/options_menu_icon_size"
            android:layout_marginLeft="@dimen/activity_margin"
            android:layout_marginRight="-8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="@dimen/margin_6"
            android:src="@drawable/ic_more"
            android:tint="@color/gray_1" />
    </LinearLayout>
</androidx.cardview.widget.CardView>