<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:gravity="center"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/completeContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="13dp"
        android:layout_marginBottom="13dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingRight="@dimen/margin_20"
        tools:background="@color/background_base">

        <RelativeLayout
            android:layout_width="@dimen/options_menu_icon_size"
            android:layout_height="@dimen/options_menu_icon_size"
            android:layout_marginRight="@dimen/activity_margin"
            android:padding="@dimen/activity_margin_half_half_half">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/circle_accent" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="@dimen/activity_margin_half_half"
                android:src="@drawable/ic_check_green"
                app:tint="@color/background_card" />
        </RelativeLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="@color/gray_4" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/margin_20"
            android:layout_marginRight="@dimen/margin_20"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dayFieldComplete"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textColor="@color/white_base"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="Mon" />

            <TextView
                android:id="@+id/dayInfoFieldComplete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/activity_margin_half_half_half"
                android:textColor="@color/gray_5"
                android:textSize="16sp"
                tools:text="Build: CHEST + TRIS" />
        </LinearLayout>

        <com.everlog.ui.views.badge.ProLockBadge
            android:id="@+id/proBadgeComplete"
            android:layout_width="@dimen/options_menu_icon_size"
            android:layout_height="@dimen/options_menu_icon_size"
            android:layout_marginRight="-8dp"
            android:padding="@dimen/activity_margin_half_half_half"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/incompleteContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="13dp"
        android:layout_marginBottom="13dp"
        android:orientation="horizontal"
        tools:background="@color/background_base">

        <ImageView
            android:id="@+id/incompleteCheck"
            android:layout_width="@dimen/options_menu_icon_size"
            android:layout_height="@dimen/options_menu_icon_size"
            android:layout_marginTop="@dimen/margin_26"
            android:layout_marginRight="@dimen/activity_margin"
            android:padding="@dimen/activity_margin_half_half_half"
            android:src="@drawable/circle_border_accent" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/background_card"
            app:cardCornerRadius="@dimen/card_radius_default">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="@dimen/margin_20">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/dayFieldIncomplete"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:textColor="@color/white_base"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="Mon" />

                        <TextView
                            android:id="@+id/dayInfoFieldIncomplete"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/activity_margin_half_half_half"
                            android:textColor="@color/gray_5"
                            android:textSize="16sp"
                            tools:text="Build: CHEST + TRIS" />
                    </LinearLayout>

                    <com.everlog.ui.views.badge.ProLockBadge
                        android:id="@+id/proBadgeIncomplete"
                        android:layout_width="@dimen/options_menu_icon_size"
                        android:layout_height="@dimen/options_menu_icon_size"
                        android:layout_marginLeft="@dimen/activity_margin"
                        android:layout_marginRight="-8dp"
                        android:padding="@dimen/activity_margin_half_half_half"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <ImageView
                        android:id="@+id/planMenuBtn"
                        android:layout_width="@dimen/options_menu_icon_size"
                        android:layout_height="@dimen/options_menu_icon_size"
                        android:layout_marginLeft="@dimen/activity_margin"
                        android:layout_marginRight="-8dp"
                        android:padding="@dimen/margin_6"
                        android:src="@drawable/ic_more"
                        app:tint="@color/gray_1" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/buttonsLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <Button
                        android:id="@+id/skipBtn"
                        style="@style/Button.Two"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingLeft="0dp"
                        android:paddingRight="0dp"
                        android:text="@string/home_week_plan_skip" />

                    <Button
                        android:id="@+id/startBtn"
                        style="@style/Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingLeft="0dp"
                        android:paddingRight="0dp"
                        android:text="@string/home_week_plan_start" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</LinearLayout>