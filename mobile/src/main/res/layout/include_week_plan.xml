<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/planParentView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    tools:background="@color/background_base">

    <androidx.cardview.widget.CardView
        android:id="@+id/planProgressView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_26"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/background_card"
        app:cardCornerRadius="@dimen/card_radius_default"
        app:cardElevation="@dimen/card_elevation_default">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/activity_margin_half_half"
            android:layout_marginBottom="@dimen/activity_margin_half_half"
            android:orientation="vertical"
            android:paddingLeft="@dimen/activity_margin"
            android:paddingTop="@dimen/activity_margin_half"
            android:paddingRight="@dimen/activity_margin"
            android:paddingBottom="@dimen/activity_margin_half">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/planNameLbl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/white_base"
                    android:textSize="17sp"
                    tools:text="Plan Name" />

                <TextView
                    android:id="@+id/planProgressLbl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white_base"
                    tools:text="0 %" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/planProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/activity_margin_half"
                android:background="@drawable/progress_bar_horizontal"
                android:indeterminate="false"
                android:max="100"
                android:progressDrawable="@drawable/progress_bar_horizontal"
                android:scaleY="0.4"
                tools:progress="50" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <include
        layout="@layout/shimmer_week_plan"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/planContentView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:orientation="vertical">

        <TextView
            android:id="@+id/planWeekLbl"
            style="@style/SettingsCategory.Large"
            android:layout_marginTop="@dimen/activity_margin_half"
            android:layout_marginBottom="@dimen/margin_18"
            android:gravity="center"
            android:textColor="@color/white_base"
            tools:text="Week 1 of 12" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/planWeekList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            tools:itemCount="1"
            tools:listitem="@layout/row_plan_day" />

        <Button
            android:id="@+id/finishPlanBtn"
            style="@style/Button"
            android:layout_width="match_parent"
            android:layout_marginTop="@dimen/activity_margin_actual"
            android:text="@string/home_week_plan_finish"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>
</LinearLayout>